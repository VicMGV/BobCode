# ============================================
# IBM Bob API Configuration
# ============================================
# Required for full functionality. Without these, the agent runs in mock mode.
# 
# How to get your credentials:
# 1. Visit IBM watsonx.ai platform: https://www.ibm.com/watsonx
# 2. Sign up or log in to your IBM Cloud account
# 3. Navigate to watsonx.ai service
# 4. Create a new project or select existing one
# 5. Go to API Keys section in your profile/project settings
# 6. Generate a new API key
# 7. Copy the API endpoint URL and API key below

# IBM Bob API Endpoint URL
# Format: https://[region].ml.cloud.ibm.com/ml/v1/text/chat
# Example: https://us-south.ml.cloud.ibm.com/ml/v1/text/chat
BOB_API_URL=https://us-south.ml.cloud.ibm.com

# IBM Bob API Key
# Format: Alphanumeric string with dashes/underscores (minimum 10 characters)
# Example: abcd1234-efgh-5678-ijkl-9012mnop3456
BOB_API_KEY=fCIiwlzmmNUUJbV7BzDHI4WTINMraS0X1ODizVeEHESi

# ============================================
# Application Configuration
# ============================================

# Environment mode (development, production, test)
NODE_ENV=development

# Logging level (error, warn, info, debug)
LOG_LEVEL=info

# ============================================
# Optional: Advanced Configuration
# ============================================

# Server port (if using web interface)
# PORT=3000

# Maximum file size for operations (in bytes)
# MAX_FILE_SIZE=10485760

# API request timeout (in milliseconds)
# API_TIMEOUT=30000